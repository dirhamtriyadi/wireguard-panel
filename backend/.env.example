# Server
SERVER_PORT=8080
GIN_MODE=debug

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=wg_panel
DB_SSLMODE=disable

# Public endpoint clients dial (used as a fallback for client configs)
DEFAULT_ENDPOINT=vpn.example.com

# CORS (comma separated, * for all)
CORS_ALLOW_ORIGINS=http://localhost:5173

# Auth (single admin login)
# Set these on first setup. With AUTH_PASSWORD empty, login is disabled and the
# whole API is locked. Change the password before exposing the panel.
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
# Secret used to sign session tokens. Use a long random string in production
# (e.g. `openssl rand -hex 32`). If left empty, an ephemeral secret is generated
# on startup and all sessions reset whenever the server restarts.
AUTH_TOKEN_SECRET=
# Session lifetime in hours (default 24).
AUTH_TOKEN_TTL_HOURS=24
